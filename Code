file_10dai_name = os.path.join(BASE_PATH, "Ghaemli.xlsx - siggenes-IR vs IS 10dai-not com.csv")

# --- Phase 1: Load, Combine, and Filter Differential Expression Data ---

def load_clean_filter_deg(filepath, timepoint):
    # CRITICAL FIX 1: Use header=0 (the first row) as confirmed by file snippets.
    try:
        data = pd.read_csv(filepath, header=0)
    except pd.errors.ParserError:
        # Fallback for non-standard separators (like tabs)
        data = pd.read_csv(filepath, header=0, sep='\t')
    
    # CRITICAL FIX 2: Strip all leading/trailing whitespace from column names
    # This prevents invisible spaces from breaking the 'Gene name' lookup.
    data.columns = data.columns.str.strip()
    
    # CRITICAL FIX 3: Only rename 'Gene description' to 'Gene_description' for script consistency,
    # and confirm 'Gene name' and 'log2FoldChange' retain their exact user-specified names.
    data = data.rename(columns={
        'Gene description': 'Gene_description' 
        # Note: 'Gene name' and 'log2FoldChange' are used as is after stripping.
    })
    
    # 3. Select columns using the consistent names
    # 'Gene name' (with space) and 'Gene_description' (with underscore)
    data = data[['Gene name', 'log2FoldChange', 'Gene_description']].copy()
    
    data['Time_point'] = timepoint
    data['log2FoldChange'] = pd.to_numeric(data['log2FoldChange'], errors='coerce')
    data = data.dropna(subset=['log2FoldChange'])
    
    # Filter for core resistance candidates (Log2 Fold Change > 1.5)
    data = data[data['log2FoldChange'] > 1.5]
    return data

try:
    print("Loading and filtering actual CSV data...")
    deg_4dai = load_clean_filter_deg(file_4dai_name, "4dai")
    deg_10dai = load_clean_filter_deg(file_10dai_name, "10dai")

    core_resistance_genes = pd.concat([deg_4dai, deg_10dai], ignore_index=True)
    # Use 'Gene name' for subsetting
    core_resistance_genes = core_resistance_genes.sort_values(by='log2FoldChange', ascending=False).drop_duplicates(subset='Gene name', keep='first')

    print(f"Phase 1 SUCCESS: Found {len(core_resistance_genes)} core resistance candidate genes with Log2FC > 1.5.")
    print("\nTop 5 Final Candidates:")
    print(core_resistance_genes.head().to_markdown(index=False))
    
    # Save the full list of candidates to the BASE_PATH
    core_resistance_genes.to_csv(os.path.join(BASE_PATH, "full_core_resistance_candidates.csv"), index=False)
    
except FileNotFoundError as e:
